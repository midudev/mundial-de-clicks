---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import LiveStats from '../components/LiveStats.astro';
import VotingGrid from '../components/VotingGrid.astro';
import Ranking from '../components/Ranking.astro';
import LiveEvents from '../components/LiveEvents.astro';
import { buildRanking } from '../lib/ranking';
import type { WorldSnapshot } from '../lib/types';

// Página ESTÁTICA (prerender): se genera una vez en el build y se sirve
// como un HTML fijo, con coste de CPU casi nulo y cacheable en CDN. Bajo
// una avalancha de cargas, esto es lo que más ayuda a que no se caiga.
// Los datos reales (votos, ranking) los rellena el cliente por SSE nada
// más cargar, así que no necesitamos renderizar el estado en el servidor.
export const prerender = true;

// Estado inicial vacío (todos a 0). El cliente lo sustituye al instante.
const snapshot: WorldSnapshot = {
  ranking: buildRanking(new Map()),
  totalVotes: 0,
  clicksPerSecond: 0,
  blockedClicks: 0,
  events: [],
};
---

<Layout>
  <main class="mx-auto w-full max-w-6xl px-4 pb-16">
    <Hero />

    <div class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1fr)_320px]">
      <!-- Columna principal -->
      <div class="flex flex-col gap-8">
        <LiveStats snapshot={snapshot} />
        <VotingGrid />
        <Ranking snapshot={snapshot} />
      </div>

      <!-- Barra lateral: retransmisión en directo -->
      <div class="lg:sticky lg:top-4 lg:self-start">
        <LiveEvents />
      </div>
    </div>
  </main>
</Layout>

<script>
  import '../scripts/main.ts';
</script>
