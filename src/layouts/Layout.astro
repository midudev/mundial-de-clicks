---
import '../styles/global.css';
import FlagSprite from '../components/FlagSprite.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Mundial de Clicks',
  description = 'Apoya a tu selección haciendo clicks. Ranking en tiempo real.',
} = Astro.props;

// Analytics con Umami (opcional): se activa solo si defines las variables.
const umamiSrc = import.meta.env.PUBLIC_UMAMI_SCRIPT_URL;
const umamiWebsiteId = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    {
      umamiSrc && umamiWebsiteId && (
        <script
          is:inline
          define:vars={{ umamiSrc, umamiWebsiteId }}
        >
          {`
          // Cargamos Umami de forma totalmente asíncrona y fuera del camino
          // crítico: si el servidor tarda o no responde, no bloquea ni retrasa
          // el resto de scripts ni la interactividad de la página.
          (function () {
            function loadUmami() {
              var s = document.createElement('script');
              s.src = umamiSrc;
              s.async = true;
              s.setAttribute('data-website-id', umamiWebsiteId);
              s.onerror = function () { s.remove(); };
              document.head.appendChild(s);
            }
            if (document.readyState === 'complete') {
              loadUmami();
            } else {
              window.addEventListener('load', loadUmami);
            }
          })();
          `}
        </script>
      )
    }
  </head>
  <body>
    <FlagSprite />
    <slot />
  </body>
</html>
